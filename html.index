<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Equi Proposal</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800;900&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS with Custom Color Config -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        pink: {
                            400: '#FF4D79',
                            500: '#FF285A', // Target Shade: R255 G40 B90
                            600: '#E62451',
                            900: '#661024',
                        }
                    }
                }
            }
        }
    </script>
    
    <!-- Three.js & RoundedBoxGeometry -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/geometries/RoundedBoxGeometry.js"></script>

    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #000000;
            overflow-x: hidden; 
            font-family: 'Inter', sans-serif;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            transition: background-color 1s ease;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #000000; 
        }
        ::-webkit-scrollbar-thumb {
            background: #333; 
            border-radius: 0px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #555; 
        }

        #canvas-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100vh;
            z-index: 0;
            pointer-events: none;
            transition: opacity 0.5s ease;
        }

        .font-montserrat {
            font-family: 'Montserrat', sans-serif;
        }

        .text-glow {
            text-shadow: 0 0 40px rgba(0,0,0,0.8), 0 0 80px rgba(0,0,0,1.0);
        }
    </style>
</head>
<body class="text-white selection:bg-pink-500 selection:text-white">

