        <!-- Section 1 UI (The Maze) -->
        <div id="ui-sec-1" class="fixed top-0 left-0 w-full h-screen z-10 flex flex-col items-start justify-end pointer-events-none will-change-transform pb-24 pl-8 md:pl-24">
